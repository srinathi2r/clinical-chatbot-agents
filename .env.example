# Fill in one of these. CrewAI will use whichever is set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Shared CrewAI model configuration for all five agents.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# For Anthropic:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6

# Vector index settings (built by scripts/build_index.py)
EMBEDDING_PROVIDER=openai
CHROMA_INDEX_PATH=data/vector_index
RETRIEVAL_TOP_K=4

# Set to 1 to see verbose CrewAI agent logs
CREWAI_VERBOSE=0

# Fill in one of these. CrewAI will use whichever is set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (defaults shown)
CREW_LLM_MODEL=gpt-4o
# CREW_LLM_MODEL=claude-opus-4-7

# Vector index path (built by scripts/build_index.py)
FAISS_INDEX_PATH=data/faiss_index

# Set to 1 to see verbose CrewAI agent logs
CREWAI_VERBOSE=0
